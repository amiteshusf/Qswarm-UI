# Local development: use embedded mock API (no backend required).
VITE_USE_MOCK_DATA=true

# Real API against a remote host (uncomment and flip mock flag):
# VITE_USE_MOCK_DATA=false
# VITE_API_BASE_URL=https://qswarm.onrender.com

# Real API via local reverse proxy to /api/v1 (uncomment all three):
# VITE_USE_MOCK_DATA=false
# VITE_ALLOW_SAME_ORIGIN_API=true
# (leave VITE_API_BASE_URL unset)
