# Copy to `.env.local` for local overrides.

# --- Mock mode (no network) ---
# VITE_USE_MOCK_DATA=true

# --- Real API ---
# API origin only: no trailing slash, no path-prefix suffix.
# VITE_API_BASE_URL=https://qswarm.onrender.com
# VITE_USE_MOCK_DATA=false
# Optional. Default is /api/v1. Use empty for root-mounted APIs:
# VITE_API_PATH_PREFIX=

# --- Dev only: relative /api/v1 (e.g. local reverse proxy) ---
# VITE_USE_MOCK_DATA=false
# VITE_ALLOW_SAME_ORIGIN_API=true
